# Copy to .env (in this same repo-root directory) and fill in.

# Required — OpenRouter API key (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-...

# Optional — override default models (defaults in crop_agent/config.py)
# REASONER_MODEL=openai/gpt-4o-mini
# WORKER_MODEL=meta-llama/llama-3.1-8b-instruct

# Optional — real web search (Tavily). Without this, runs use canned stub data.
# SEARCH_API_KEY=tvly-...
